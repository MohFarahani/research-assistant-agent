# Copy this file to docker-compose.override.yml for local dev hot-reload.
# docker-compose.override.yml is git-ignored — never commit it.

services:
  backend:
    build:
      context: .
      dockerfile: docker/backend.Dockerfile
    command: uv run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload
    volumes:
      - ./backend:/app

  frontend:
    build:
      context: .
      dockerfile: docker/frontend.Dockerfile
    command: pnpm dev
    volumes:
      - ./frontend/src:/app/src
      - ./frontend/public:/app/public
