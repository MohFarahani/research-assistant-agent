{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "frontend", "dev"],
      "port": 3000
    },
    {
      "name": "Backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["--dir", "backend","app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    }
  ]
}
