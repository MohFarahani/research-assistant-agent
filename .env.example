# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM Provider ────────────────────────────────────────────────────────────
# Choose: "gemini" (free), "groq" (free), "anthropic" (paid), "openai" (paid)
LLM_PROVIDER=gemini

# ── Google AI Studio — FREE tier ────────────────────────────────────────────
# Get your key at https://aistudio.google.com/apikey
# Free: 15 requests/min, 1 million token context window
# Also used for embeddings when LLM_PROVIDER=groq
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── Groq — FREE tier ────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
# Free: fast inference on open-source models (Llama 3)
# Note: Groq has no embeddings API — GEMINI_API_KEY is also required for embeddings
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic — paid ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI — paid ───────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# ── Embedding dimensions ─────────────────────────────────────────────────────
# Must match the Qdrant collection vector size.
# 768  → Gemini embeddings (gemini-embedding-001)
# 1536 → OpenAI embeddings (text-embedding-3-small)
# WARNING: changing this requires re-uploading all documents (new Qdrant collection).
EMBEDDING_DIMENSIONS=768

# ── Infrastructure ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_assistant
QDRANT_HOST=localhost
QDRANT_PORT=6333
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
